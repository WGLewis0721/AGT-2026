## CHANGE 2 — terraform/pricing-lambda.tf — Create new file

Create a NEW file: backend-integration/terraform/pricing-lambda.tf

This file is entirely new — it does not modify any existing .tf files.

IMPORTANT — before adding the locals block below, run this check:

```powershell
Select-String -Path backend-integration\terraform\*.tf -Pattern "^locals" -SimpleMatch
```

If a locals block already exists in any .tf file, add the two new
local values (pricing_function_name, pricing_zip_s3_key) to that
existing block instead of creating a new one. Terraform merges locals
across files but will error on duplicate block declarations in some
versions. If no locals block exists anywhere, create the new block
as shown below.

```hcl
# ─── TRA3 Pricing API Lambda ─────────────────────────────────────────────────
# Separate from the webhook Lambda. Handles Stripe Checkout Session creation.

locals {
  pricing_function_name = "tra3-${var.client}-${var.environment}-pricing-api"
  pricing_zip_s3_key    = "functions/${var.client}/${var.environment}/pricing_lambda.zip"
}

# ─── IAM Role ────────────────────────────────────────────────────────────────

resource "aws_iam_role" "pricing_lambda_role" {
  name = "tra3-${var.client}-${var.environment}-pricing-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Action    = "sts:AssumeRole"
      Effect    = "Allow"
      Principal = { Service = "lambda.amazonaws.com" }
    }]
  })

  tags = {
    Project     = "TRA3"
    Client      = var.client
    Environment = var.environment
    ManagedBy   = "Terraform"
  }
}

resource "aws_iam_role_policy_attachment" "pricing_lambda_logs" {
  role       = aws_iam_role.pricing_lambda_role.name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
}

# ─── CloudWatch Log Group ─────────────────────────────────────────────────────

resource "aws_cloudwatch_log_group" "pricing_lambda_log_group" {
  name              = "/aws/lambda/${local.pricing_function_name}"
  retention_in_days = 14

  tags = {
    Project     = "TRA3"
    Client      = var.client
    Environment = var.environment
    ManagedBy   = "Terraform"
  }
}

# ─── S3 Upload — Pricing Lambda Zip ─────────────────────────────────────────

resource "aws_s3_object" "pricing_lambda_zip" {
  bucket = aws_s3_bucket.deployments.id
  key    = local.pricing_zip_s3_key
  source = "${path.module}/../lambda/pricing_lambda.zip"
  etag   = filemd5("${path.module}/../lambda/pricing_lambda.zip")
}

# ─── Lambda Function ─────────────────────────────────────────────────────────

resource "aws_lambda_function" "pricing_api" {
  function_name = local.pricing_function_name
  role          = aws_iam_role.pricing_lambda_role.arn
  handler       = var.pricing_lambda_handler
  runtime       = var.pricing_lambda_runtime
  timeout       = var.pricing_lambda_timeout
  memory_size   = var.pricing_lambda_memory

  s3_bucket        = aws_s3_bucket.deployments.id
  s3_key           = local.pricing_zip_s3_key
  source_code_hash = aws_s3_object.pricing_lambda_zip.etag

  layers = [aws_lambda_layer_version.dependencies.arn]

  environment {
    variables = {
      STRIPE_SECRET_KEY = var.stripe_secret_key
      ENVIRONMENT       = var.environment
      ALLOWED_ORIGIN    = var.allowed_origin
    }
  }

  tags = {
    Project     = "TRA3"
    Client      = var.client
    Environment = var.environment
    ManagedBy   = "Terraform"
  }

  lifecycle {
    replace_triggered_by = [aws_s3_object.pricing_lambda_zip]
  }
}

# ─── API Gateway Integration ──────────────────────────────────────────────────

resource "aws_apigatewayv2_integration" "pricing_integration" {
  api_id                 = aws_apigatewayv2_api.webhook_api.id
  integration_type       = "AWS_PROXY"
  integration_uri        = aws_lambda_function.pricing_api.invoke_arn
  payload_format_version = "2.0"
}

# POST /create-checkout route
resource "aws_apigatewayv2_route" "create_checkout" {
  api_id    = aws_apigatewayv2_api.webhook_api.id
  route_key = "POST /create-checkout"
  target    = "integrations/${aws_apigatewayv2_integration.pricing_integration.id}"
}

# OPTIONS /create-checkout route (CORS preflight)
resource "aws_apigatewayv2_route" "create_checkout_options" {
  api_id    = aws_apigatewayv2_api.webhook_api.id
  route_key = "OPTIONS /create-checkout"
  target    = "integrations/${aws_apigatewayv2_integration.pricing_integration.id}"
}

# Lambda permission for API Gateway
resource "aws_lambda_permission" "pricing_api_gateway" {
  statement_id  = "AllowAPIGatewayInvokePricing"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.pricing_api.function_name
  principal     = "apigateway.amazonaws.com"
  source_arn    = "${aws_apigatewayv2_api.webhook_api.execution_arn}/*/*"

  lifecycle {
    replace_triggered_by = [aws_lambda_function.pricing_api]
  }
}

# ─── Outputs ─────────────────────────────────────────────────────────────────

output "pricing_api_url" {
  description = "URL for the TRA3 Pricing API create-checkout endpoint"
  value       = "${aws_apigatewayv2_stage.default.invoke_url}/create-checkout"
}

output "pricing_lambda_name" {
  description = "Pricing Lambda function name"
  value       = aws_lambda_function.pricing_api.function_name
}
```

